{
  "name": "shelf",
  "version": "0.1.0",
  "description": "Tiny CLI for accountable temporary artifact retention.",
  "type": "module",
  "author": "Calvin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/calvinnwq/shelf.git"
  },
  "bugs": {
    "url": "https://github.com/calvinnwq/shelf/issues"
  },
  "homepage": "https://calvinnwq.github.io/shelf/",
  "keywords": [
    "artifact-retention",
    "cleanup",
    "cli",
    "jsonl",
    "tmp"
  ],
  "bin": {
    "shelf": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "docs",
    "skills",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "SPEC.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
