    "check": "pnpm run build && pnpm run test",
    "start": "node dist/src/cli.js"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.3",
  "license": "MIT"
}
